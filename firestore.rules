rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES --- //
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.token.email == 'altamedia51@gmail.com');
    }

    function isGuru() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'guru';
    }

    // --- RULES --- //

    // 1. Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (userId == request.auth.uid || isAdmin());
    }

    // 2. Siswa
    match /siswa/{siswaId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isGuru());
    }

    // 3. Guru
    match /guru/{guruId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. Kelas
    match /kelas/{kelasId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    // 5. Mapel
    match /mapel/{mapelId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    // 6. Paket Soal
    match /paket_soal/{paketId} {
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && (isAdmin() || isGuru());
    }

    // 7. Soal 
    match /paket_soal/{paketId}/soal/{soalId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isGuru());
    }

    // 8. Ujian
    match /ujian/{ujianId} {
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && (isAdmin() || isGuru());
    }

    // 9. Hasil Ujian
    match /hasil_ujian/{hasilId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 10. Pelanggaran
    match /hasil_ujian/{hasilId}/pelanggaran/{pelanggaranId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 11. Jawaban Siswa
    match /jawaban_siswa/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
